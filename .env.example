# ============================================================
# Variables de entorno para SysInventarios
# Copia este archivo como .env (NO lo subas a GitHub)
# En Netlify: configura estas variables en Site Settings > Env Vars
# ============================================================

# Gemini AI (Google AI Studio: https://aistudio.google.com)
GEMINI_API_KEY=AIza...tu_clave_aqui

# Firebase (Firebase Console > Project Settings > Web App)
# Nota: La config de Firebase puede ser pública; la seguridad
# la manejan las Security Rules de Firestore.
FIREBASE_API_KEY=AIza...
FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abc123
